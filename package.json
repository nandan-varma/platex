{
  "name": "@nandan-varma/platex",
  "version": "0.0.3",
  "description": "Compile LaTeX to PDF binary matching Overleaf output, with Next.js support",
  "license": "MIT",
  "author": "Nandan Varma",
  "homepage": "https://github.com/nandan-varma/platex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nandan-varma/platex.git"
  },
  "bugs": {
    "url": "https://github.com/nandan-varma/platex/issues"
  },
  "keywords": [
    "latex",
    "tex",
    "pdf",
    "overleaf",
    "pdflatex",
    "tectonic",
    "nextjs",
    "vercel",
    "compile"
  ],
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "require": "./dist/client.cjs"
    },
    "./server": {
      "types": "./dist/server-app.d.ts",
      "import": "./dist/server-app.js",
      "require": "./dist/server-app.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "build:server": "tsup --config tsup.server.config.ts",
    "build:vercel": "node scripts/download-tectonic.mjs && tsup --config tsup.server.config.ts",
    "dev": "tsx src/server/index.ts",
    "demo": "npm run build && npm --prefix examples/nextjs-demo install && npm --prefix examples/nextjs-demo run dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "format": "biome format --write src/",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.8",
    "@hono/zod-validator": "^0.4.3",
    "hono": "^4.7.11",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@types/node": "^22.15.21",
    "tsup": "^8.5.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  },
  "peerDependencies": {
    "typescript": ">=5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
